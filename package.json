{
    "name": "@elliot-labs/chat-engine",
    "version": "0.0.1",
    "description": "Extendable engine used to interact with LLMs.",
    "keywords": [
        "AI",
        "LLM",
        "chat",
        "automation"
    ],
    "homepage": "https://github.com/elliot-labs/chat-engine#readme",
    "bugs": {
        "url": "https://github.com/elliot-labs/chat-engine/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/elliot-labs/chat-engine.git"
    },
    "license": "MIT",
    "packageManager": "npm@12.0.1",
    "devEngines": {
        "packageManager": {
            "name": "npm",
            "version": "12.0.1"
        },
        "runtime": {
            "name": "node",
            "version": "24.18.0"
        }
    },
    "author": "Elliot Huffman (elliot@huffman.me)",
    "type": "module",
    "main": "bin/src/index.js",
    "scripts": {
        "build:Dev": "tsc",
        "prebuild:Prod": "tsc -p prod.tsconfig.json --emitDeclarationOnly false",
        "build:Prod": "tsc -p prod.tsconfig.json --removeComments false",
        "lint": "eslint --max-warnings 0",
        "test:Unit": "echo \"No unit tests yet!\"",
        "test:Integration": "echo \"No integration tests yet!\"",
        "prepare": "ts-patch install"
    },
    "dependencies": {
        "@azure/identity": "~4.13.1",
        "openai": "~6.48.0",
        "typia": "~12.1.1"
    },
    "devDependencies": {
        "@azure/core-auth": "~1.11.0",
        "@software-hardware-integration-lab/development-utilities": "~3.0.0",
        "@types/node": "~26.1.1",
        "ts-patch": "~4.0.1",
        "typescript": "~6.0.3"
    },
    "overrides": {
        "function-bind": "npm:@socketregistry/function-bind@^1",
        "hasown": "npm:@socketregistry/hasown@^1",
        "is-core-module": "npm:@socketregistry/is-core-module@^1",
        "is-interactive": "npm:@socketregistry/is-interactive@^1",
        "is-unicode-supported": "npm:@socketregistry/is-unicode-supported@^1",
        "path-parse": "npm:@socketregistry/path-parse@^1",
        "safe-buffer": "npm:@socketregistry/safe-buffer@^1",
        "safer-buffer": "npm:@socketregistry/safer-buffer@^1"
    },
    "resolutions": {
        "function-bind": "npm:@socketregistry/function-bind@^1",
        "hasown": "npm:@socketregistry/hasown@^1",
        "is-core-module": "npm:@socketregistry/is-core-module@^1",
        "is-interactive": "npm:@socketregistry/is-interactive@^1",
        "is-unicode-supported": "npm:@socketregistry/is-unicode-supported@^1",
        "path-parse": "npm:@socketregistry/path-parse@^1",
        "safe-buffer": "npm:@socketregistry/safe-buffer@^1",
        "safer-buffer": "npm:@socketregistry/safer-buffer@^1"
    }
}
